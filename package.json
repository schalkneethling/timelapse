{
  "name": "timelapse",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "vp build",
    "preview": "vp preview",
    "typecheck": "tsc --noEmit",
    "check": "vp check && pnpm typecheck && stylelint \"src/**/*.css\"",
    "check:fix": "stylelint \"src/**/*.css\" --fix && vp check --fix"
  },
  "dependencies": {
    "lit": "^3.3.2"
  },
  "devDependencies": {
    "stylelint": "^17.5.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^8.1.1",
    "typescript": "^5.9.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plus": "latest",
    "workbox-window": "^7.4.0"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  }
}
